{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!.*\\.(?:ico|png|jpg|jpeg|svg|webp|gif|woff2?|ttf|otf|eot|json|txt|xml|js|css|map|mp4|webm|ogg|mp3|wav|pdf|zip|wasm)).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(?:ico|png|jpg|jpeg|svg|webp|gif|woff2?|ttf|otf|eot|json|txt|xml|js|css|wasm|pdf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
