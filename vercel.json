{
  "buildCommand": "cd artifacts/file-nova && pnpm install && pnpm build",
  "outputDirectory": "artifacts/file-nova/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!.*\\.(?:ico|png|jpg|jpeg|svg|webp|gif|woff2?|ttf|otf|eot|json|txt|xml|js|css|map|mp4|webm|ogg|mp3|wav|pdf|zip|wasm)).*)",
      "destination": "/index.html"
    }
  ]
}
